{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "env": {
    "VITE_SUPABASE_PROJECT_ID": "@supabase_project_id",
    "VITE_SUPABASE_PUBLISHABLE_KEY": "@supabase_key",
    "VITE_SUPABASE_URL": "@supabase_url",
