# ⚠️ ESTE É UM ARQUIVO DE EXEMPLO
# Copie para .env e preencha com seus valores reais
# NUNCA commite .env com secrets reais no git!

# ===== SUPABASE =====
# Obtenha em: https://supabase.com/dashboard
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_jwt_token_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co

# SERVICE ROLE KEY (obtenha em Settings > API > Service role / secret)
# ⚠️ NUNCA exponha isso no frontend ou commit no git!
# Apenas no backend para operações administrativas
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===== ABACATEPAY =====
# Obtenha em: https://dashboard.abacatepay.com
# Para DESENVOLVIMENTO: Use abc_dev_*KEY
# Para PRODUÇÃO: Use abc_prod_*KEY
VITE_ABACATEPAY_KEY=abc_dev_your_key_here

# ===== WEBHOOK SECRET =====
# Gere uma senha FORTE e SEGURA (mínimo 32 caracteres aleatórios)
# Exemplo: openssl rand -base64 32
# NUNCA use "qwe123123" em produção!
ABACATEPAY_WEBHOOK_SECRET=your_strong_secret_here_min_32_chars

# ===== BACKEND =====
# URL do backend (apenas para desenvolvimento local)
VITE_BACKEND_URL=http://localhost:3001
PORT=3001
